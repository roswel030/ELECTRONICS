<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net" />
    <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
      <section name="UTN.Winform.Electronics.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
    </sectionGroup>
  </configSections>
  <!--Parámetros-->
  <appSettings>
    <add key="NombreEmpresa" value="UTN Company." />
    <add key="URLPadron" value="https://api.hacienda.go.cr/fe/ae?identificacion=" />
    <add key="URLProvincia" value="https://raw.githubusercontent.com/lateraluz/Datos/refs/heads/master/provincias.json" />   
  </appSettings>
  <!--Conexion de la base de Datos-->
  <connectionStrings>
    <add name="default" connectionString="Data Source=localhost;Initial Catalog=Electronics;Integrated Security=false;MultipleActiveResultSets=true;Application Name=Electronics APP;User Id=sa;Password=Abs2025sysco"
      providerName="System.Data.SqlClient" />
    <add name="UTN.Winform.Electronics.Properties.Settings.ElectronicsConnectionString"
      connectionString="Data Source=.;Initial Catalog=Electronics;User ID=sa;Password=Abs2025sysco"
      providerName="System.Data.SqlClient" />
  </connectionStrings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <log4net>
    <root>
      <level value="ALL" />
      <appender-ref ref="MyControlEventos" />
    </root>
    <appender name="MyControlEventos" type="log4net.Appender.FileAppender">
      <file type="log4net.Util.PatternString" value="c:\temp\Eventos-%date{yyyy-MM-dd}.txt" />
      <appendToFile value="true" />
      <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date %level -%message%newline" />
      </layout>
    </appender>
  </log4net>
  <userSettings>
    <UTN.Winform.Electronics.Properties.Settings>
      <setting name="Login" serializeAs="String">
        <value />
      </setting>
      <setting name="Nombre" serializeAs="String">
        <value />
      </setting>
      <setting name="RolId" serializeAs="String">
        <value />
      </setting>
    </UTN.Winform.Electronics.Properties.Settings>
  </userSettings>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Runtime.CompilerServices.Unsafe" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-6.0.3.0" newVersion="6.0.3.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Numerics.Vectors" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.1.6.0" newVersion="4.1.6.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Buffers" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.5.0" newVersion="4.0.5.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Memory" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.5.0" newVersion="4.0.5.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Threading.Tasks.Extensions" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.2.4.0" newVersion="4.2.4.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime> 
  <system.web>  
  </system.web>
</configuration>